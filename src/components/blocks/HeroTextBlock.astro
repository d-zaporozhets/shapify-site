---
const { title, subtitle, backgroundImage, ctaText, ctaLink } = Astro.props
---

<section class="hero-text-block" style={backgroundImage ? `background-image: url(${backgroundImage.url})` : ''}>
  <div class="container">
    <div class="content">
      <h1>{title}</h1>
      {subtitle && <p class="subtitle">{subtitle}</p>}
      {ctaText && ctaLink && (
        <a href={ctaLink} class="cta-button">{ctaText}</a>
      )}
    </div>
  </div>
</section>

<style>
.hero-text-block {
  min-height: 60vh;
  display: flex;
  align-items: center;
  justify-content: center;
  background-size: cover;
  background-position: center;
  color: white;
  text-align: center;
  padding: 4rem 1rem;
}
.hero-text-block .container {
  max-width: 800px;
  margin: 0 auto;
}
.hero-text-block h1 {
  font-size: 3rem;
  margin-bottom: 1rem;
}
.hero-text-block .subtitle {
  font-size: 1.5rem;
  margin-bottom: 2rem;
  opacity: 0.9;
}
.hero-text-block .cta-button {
  display: inline-block;
  padding: 1rem 2rem;
  background: white;
  color: #333;
  text-decoration: none;
  border-radius: 4px;
  font-weight: bold;
  transition: transform 0.2s;
}
.hero-text-block .cta-button:hover {
  transform: translateY(-2px);
}
</style>