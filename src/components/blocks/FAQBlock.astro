---
const { title, items } = Astro.props
---

<section class="faq-block">
  <div class="container">
    {title && <h2 class="section-title">{title}</h2>}
    <div class="faq-items">
      {items?.map((item, index) => (
        <div class="faq-item" key={index}>
          <button class="faq-question" onclick={`this.nextElementSibling.classList.toggle('active')`}>
            {item.question}
            <span class="toggle-icon">+</span>
          </button>
          <div class="faq-answer">
            <div set:html={item.answer} />
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
.faq-block {
  padding: 4rem 0;
}
.faq-block .container {
  max-width: 800px;
  margin: 0 auto;
  padding: 0 1rem;
}
.faq-block .section-title {
  text-align: center;
  margin-bottom: 3rem;
  font-size: 2.5rem;
}
.faq-block .faq-items {
  display: flex;
  flex-direction: column;
  gap: 1rem;
}
.faq-block .faq-item {
  border: 1px solid #e5e5e5;
  border-radius: 8px;
  overflow: hidden;
}
.faq-block .faq-question {
  width: 100%;
  padding: 1.5rem;
  background: white;
  border: none;
  text-align: left;
  font-size: 1.1rem;
  font-weight: 600;
  cursor: pointer;
  display: flex;
  justify-content: space-between;
  align-items: center;
  transition: background 0.2s;
}
.faq-block .faq-question:hover {
  background: #f9f9f9;
}
.faq-block .toggle-icon {
  font-size: 1.5rem;
  transition: transform 0.3s;
}
.faq-block .faq-answer {
  max-height: 0;
  overflow: hidden;
  transition: max-height 0.3s ease;
  padding: 0 1.5rem;
}
.faq-block .faq-answer.active {
  max-height: 500px;
  padding: 0 1.5rem 1.5rem;
}
</style>