---
// Layout.astro
import { getHeader, getFooter } from '../lib/payload';

export interface Props {
  title?: string;
  description?: string;
  pageClass?: string;
}

const { title = "Shapify", description = "3D printed figurines: 3D print yourself using a 3D portrait made in Shapify Booth in a matter of minutes. Shapify is a simple, user-friendly service to get your Shapie — your 3D selfie.", pageClass = "" } = Astro.props;
const currentPath = Astro.url.pathname;

const header = await getHeader();
const footer = await getFooter();
const navItems = header?.navItems || [];
const socialLinks = footer?.socialLinks || [];
const contactEmail = footer?.contactEmail || 'support@shapify.me';
