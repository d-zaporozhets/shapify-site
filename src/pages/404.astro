---
import Layout from '../layouts/Layout.astro'
---

<Layout title="Page Not Found">
  <main class="page-content">
    <div class="container">
      <h1>404 - Page Not Found</h1>
      <p>The page you're looking for doesn't exist.</p>
      <a href="/" class="button">Go Home</a>
    </div>
  </main>
</Layout>

<style>
.container {
  max-width: 800px;
  margin: 0 auto;
  padding: 4rem 1rem;
  text-align: center;
}
h1 {
  font-size: 3rem;
  margin-bottom: 1rem;
}
p {
  font-size: 1.2rem;
  margin-bottom: 2rem;
  color: #666;
}
.button {
  display: inline-block;
  padding: 1rem 2rem;
  background: #333;
  color: white;
  text-decoration: none;
  border-radius: 4px;
  font-weight: bold;
}
</style>