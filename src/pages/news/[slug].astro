---
import BlogLayout from '../../layouts/BlogLayout.astro';
import { getAllPosts } from '../../lib/payload';
import { marked } from 'marked';

export async function getStaticPaths() {
  const posts = await getAllPosts();
  return posts.map(post => ({
    params: { slug: post.slug },
    props: { post },
  }));
}

const { post } = Astro.props;
const title = post.title;
const description = post.description || '';

function extractMarkdown(content: any): string {
  if (!content) return ''
  if (typeof content === 'string') return content
  if (content.root?.children) {
    return content.root.children.map((node: any) => {
      if (node.type === 'text') return node.text || ''
      if (node.children) return node.children.map((n: any) => n.text || '').join('')
      return ''
    }).join('\n\n')
  }
  return ''
}

const rawContent = extractMarkdown(post.content)
const htmlContent = marked(rawContent)

const formattedDate = post.date ? new Date(post.date).toLocaleDateString('en-GB', {
  day: 'numeric', month: 'short', year: 'numeric'
}).replace(',', '') : ''
---

<BlogLayout title={title} description={description}>

<h4>
  <a class='arrow' href='/news/'>
    <span>←</span>
    <span class='text'>All posts</span>
  </a>
</h4>

<article class="post">
  <span class="post-meta">
    <time datetime={post.date}>{formattedDate}</time>
  </span>

  <h2 class="post-title">{title}</h2>

  <section class="post-content">
    <div set:html={htmlContent} />
  </section>

  <h4>
    <a class='arrow' href='/news/'>
      <span>←</span>
      <span class='text'>All posts</span>
    </a>
  </h4>

  <footer class="post-footer clearfix">
    <section class="author">
      <h4>{post.author}</h4>
    </section>
    <section class="share">
      <h4>Share this post</h4>
      <a class="icon-twitter" href={`http://twitter.com/share?text=${encodeURIComponent(title)}&url=${encodeURIComponent(`https://shapify.me/news/${post.slug}/`)}`}
        target="_blank" rel="noopener noreferrer">
        <span class="hidden">Twitter</span>
      </a>
      <a class="icon-facebook" href={`https://www.facebook.com/sharer/sharer.php?u=${encodeURIComponent(`https://shapify.me/news/${post.slug}/`)}`}
        target="_blank" rel="noopener noreferrer">
        <span class="hidden">Facebook</span>
      </a>
    </section>
  </footer>
</article>

</BlogLayout>
