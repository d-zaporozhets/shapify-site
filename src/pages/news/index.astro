---
import BlogLayout from '../../layouts/BlogLayout.astro';
import { getPostsPaginated } from '../../lib/payload';

// Pagination - show 6 posts per page
const postsPerPage = 6;
const currentPage = 1;
const response = await getPostsPaginated(currentPage, postsPerPage);
const posts = response.docs;
const totalPages = response.totalPages;

const title = "Shapify News";
const description = "Thoughts, stories and ideas.";
---

<BlogLayout {title} {description}>

{posts.map(post => {
  const formattedDate = post.date ? new Date(post.date).toLocaleDateString('en-GB', {
    day: 'numeric', month: 'short', year: 'numeric'
  }).replace(',', '') : ''
  
  return (
  <article class="post">
    <div class="post-header">
      <span class="post-meta">
        <time datetime={post.date}>{formattedDate}</time>
      </span>
      <h2 class="post-title">
        <a href={`/news/${post.slug}/`}>{post.title}</a>
      </h2>
    </div>
    <section class="post-excerpt">
      <p>
        {post.description}
        <a class='read-more' href={`/news/${post.slug}/`}>Read more</a>
      </p>
    </section>
  </article>
)})}

<nav class="pagination" role="navigation">
  <span class="page-number">Page {currentPage} of {totalPages}</span>
  {currentPage < totalPages && (
    <a class="older-posts" href="/news/page/2/">Older Posts <span aria-hidden="true">→</span></a>
  )}
</nav>

</BlogLayout>