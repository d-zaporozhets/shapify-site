# Astro Environment Variables
# For local development, Payload runs on localhost:3002
# For production, update this to your Payload API URL
PAYLOAD_URL=http://localhost:3002

# Payload CMS Environment Variables (for payload/ directory)
PAYLOAD_SECRET=your-secret-key-here
DATABASE_URL=file:./data/payload.db
NEXT_PUBLIC_SERVER_URL=http://localhost:3002
NEXT_PUBLIC_PAYLOAD_URL=http://localhost:3002